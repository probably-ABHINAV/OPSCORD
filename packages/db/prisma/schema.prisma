// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// -----------------------------------------
// Core Identity & Multi-Tenancy
// -----------------------------------------

enum PlanTier {
  FREE
  PRO
  ENTERPRISE
}

enum Role {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  plan      PlanTier @default(FREE)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users    User[]
  projects Project[]
  apiKeys  ApiKey[]
}

model User {
  id           String  @id @default(cuid())
  email        String  @unique
  passwordHash String
  name         String?
  role         Role    @default(MEMBER)

  orgId        String
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ApiKey {
  id         String    @id @default(cuid())
  keyHash    String    @unique // Store SHA-256 hash, not raw key
  name       String
  lastUsedAt DateTime?

  orgId        String
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// -----------------------------------------
// Observability Domain
// -----------------------------------------

model Project {
  id          String  @id @default(cuid())
  name        String
  description String?

  orgId        String
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  events     Event[]
  incidents  Incident[]
  alertRules AlertRule[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum EventSeverity {
  INFO
  WARNING
  ERROR
  CRITICAL
}

// Events represent raw logs/webhooks from GitHub, Datadog, Sentry, etc.
model Event {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  source   String // e.g., 'github', 'sentry', 'datadog'
  type     String // e.g., 'pull_request.merged', 'alert.triggered'
  severity EventSeverity @default(INFO)
  payload  Json // Raw webhook data
  message  String? // Extracted human-readable message

  incidentId String?
  incident   Incident? @relation(fields: [incidentId], references: [id], onDelete: SetNull)

  timestamp DateTime @default(now()) // Actual event time
  createdAt DateTime @default(now()) // Ingestion time

  // Indexes for high-performance querying
  @@index([projectId, timestamp])
  @@index([source])
}

enum IncidentStatus {
  OPEN
  INVESTIGATING
  RESOLVED
  CLOSED
}

// Incidents represent a cluster of related events causing a systemic issue
model Incident {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  title       String
  description String?        @db.Text
  status      IncidentStatus @default(OPEN)
  severity    EventSeverity

  aiInsight String? @db.Text // The root cause analysis generated by Gemini

  events Event[] // Associated logs and events

  resolvedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([projectId, status])
}

model AlertRule {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  name      String
  condition Json // Criteria: { "source": "sentry", "type": "error", "threshold": 10 }
  actions   Json // Webhook URLs, Slack channels, etc.
  isEnabled Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
